APP_NAME=portfolio-backend
APP_ENV=dev
DEBUG=true
DATABASE_URL=sqlite:///./portfolio.db

# Comma separated origins, e.g. https://your-pages.pages.dev,http://localhost:8788
CORS_ORIGINS=http://localhost:8788,http://localhost:3000

# Optional API key. /api/* accepts Basic Auth or X-API-Key.
# If VIEW_USERNAME/VIEW_PASSWORD and BACKEND_API_KEY are both empty, APIs are public.
BACKEND_API_KEY=

# IBKR Flex
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
IBKR_ACCOUNT_NO=U1234567
IBKR_ACCOUNT_NAME=IBKR Main
IBKR_FLEX_SEND_URL=https://gdcdyn.interactivebrokers.com/Universal/servlet/FlexStatementService.SendRequest
IBKR_FLEX_GET_URL=https://gdcdyn.interactivebrokers.com/Universal/servlet/FlexStatementService.GetStatement
IBKR_USE_MOCK=false

# Longbridge (via Longport OpenAPI SDK)
LONGBRIDGE_ACCOUNT_NO=LONG-001
LONGBRIDGE_ACCOUNT_NAME=Longbridge Main
LONGBRIDGE_USE_MOCK=false
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_TOKEN=

# Optional web login credentials
VIEW_USERNAME=
VIEW_PASSWORD=

# Scheduler
ENABLE_SCHEDULER=false
LONGBRIDGE_SYNC_MINUTES=5
IBKR_SYNC_HOUR_UTC=22
